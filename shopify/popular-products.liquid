{%- style -%}
  .popular-products-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 768px) {
    .popular-products-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .popular-products-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
    box-sizing: border-box;
  }

  @media screen and (min-width: 768px) {
    .popular-products-container-{{ section.id }} {
      padding: 0 40px;
    }
  }

  .popular-products-grid-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  @media screen and (min-width: 640px) {
    .popular-products-grid-{{ section.id }} {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-start;
    }
  }

  @media screen and (min-width: 1024px) {
    .popular-products-grid-{{ section.id }} {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 0;
    }
  }

  .popular-products-intro-{{ section.id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
    width: 100%;
    box-sizing: border-box;
  }

  @media screen and (min-width: 1024px) {
    .popular-products-intro-{{ section.id }} {
      width: 348px;
      padding-right: 40px;
      flex-shrink: 0;
      margin-top: 10px;
      margin-bottom: 30px;
    }
  }

  .popular-products-subtitle-{{ section.id }} {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: {{ section.settings.subtitle_color }};
    margin: 20.04px 0;
    line-height: 21.6px;
    font-family: "Work Sans", sans-serif;
  }

  .popular-products-title-{{ section.id }} {
    font-family: "Outfit", sans-serif;
    font-size: 40px;
    font-weight: 500;
    line-height: 52px;
    letter-spacing: normal;
    color: {{ section.settings.text_color }};
    margin: 0 0 35px 0;
  }

  /* Product Card styling */
  .popular-product-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    position: relative;
    width: 100%;
    box-sizing: border-box;
  }

  @media screen and (min-width: 640px) {
    .popular-product-card-{{ section.id }} {
      width: calc(50% - 15px);
    }
  }

  @media screen and (min-width: 1024px) {
    .popular-product-card-{{ section.id }} {
      width: 187.5px;
      height: 358px;
      margin-right: 30px;
      flex-shrink: 0;
    }
    .popular-product-card-{{ section.id }}:last-child {
      margin-right: 0;
    }
  }

  .popular-product-image-container-{{ section.id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: {{ section.settings.card_bg_color }};
    overflow: hidden;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media screen and (min-width: 1024px) {
    .popular-product-image-container-{{ section.id }} {
      width: 187.5px;
      height: 234.375px;
      aspect-ratio: auto;
    }
  }

  .popular-product-image-container-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .popular-product-card-{{ section.id }}:hover .popular-product-image-container-{{ section.id }} img {
    transform: scale(1.05);
  }

  /* Discount badge */
  .popular-product-badge-{{ section.id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ section.settings.badge_bg_color }};
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    padding: 4px 8px;
    z-index: 5;
    font-family: "Outfit", sans-serif;
  }

  /* Hover actions stack */
  .popular-product-actions-{{ section.id }} {
    position: absolute;
    top: 10px;
    right: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .popular-product-card-{{ section.id }}:hover .popular-product-actions-{{ section.id }} {
    opacity: 1;
  }

  .popular-product-icon-btn-{{ section.id }} {
    width: 30px;
    height: 30px;
    background-color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #000000;
    border: none;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
    transition: background-color 0.3s, color 0.3s;
  }

  .popular-product-icon-btn-{{ section.id }} svg {
    width: 14px;
    height: 14px;
  }

  .popular-product-icon-btn-{{ section.id }}:hover {
    background-color: #000000;
    color: #ffffff;
  }

  /* Add to cart overlay button wrapper */
  .popular-product-quick-add-{{ section.id }} {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    height: 60px;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .popular-product-card-{{ section.id }}:hover .popular-product-quick-add-{{ section.id }} {
    opacity: 1;
  }

  .popular-product-add-cart-btn-{{ section.id }} {
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.btn_bg_color }};
    color: #ffffff;
    font-family: "Outfit", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-align: center;
    cursor: pointer;
    border: none;
    border-radius: 0px;
    padding: 0;
    margin: 0;
  }

  .popular-product-add-cart-btn-{{ section.id }}:hover {
    background-color: {{ section.settings.btn_hover_bg_color }};
  }

  /* Product details */
  .popular-product-name-{{ section.id }} {
    font-family: "Outfit", sans-serif;
    font-size: 20px;
    font-weight: 500;
    line-height: 26px;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    margin: 0px 0px 10px 0px;
    text-align: center;
    transition: color 0.2s;
    height: 52px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .popular-product-name-{{ section.id }}:hover {
    color: {{ section.settings.subtitle_color }};
  }

  .popular-product-price-container-{{ section.id }} {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 10px;
    font-family: "Work Sans", sans-serif;
    margin-top: 0px;
  }

  .popular-product-price-{{ section.id }} {
    font-size: 16px;
    font-weight: 400;
    color: {{ section.settings.text_color }};
  }

  .popular-product-compare-price-{{ section.id }} {
    font-size: 14px;
    font-weight: 400;
    text-decoration: line-through;
    color: rgba(0, 0, 0, 0.4);
  }
{%- endstyle -%}

<div class="popular-products-{{ section.id }}">
  <div class="popular-products-container-{{ section.id }}">
    <div class="popular-products-grid-{{ section.id }}">
      
      <!-- Left Column: Intro Details -->
      <div class="popular-products-intro-{{ section.id }}">
        {%- if section.settings.subtitle != blank -%}
          <span class="popular-products-subtitle-{{ section.id }}">{{ section.settings.subtitle | escape }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="popular-products-title-{{ section.id }}">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>

      <!-- Product Columns -->
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection != blank and collection.all_products_count > 0 -%}
        {%- for product in collection.products limit: 4 -%}
          <div class="popular-product-card-{{ section.id }}">
            <div class="popular-product-image-container-{{ section.id }}">
              
              <!-- Product Image -->
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title | escape }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}

              <!-- Savings Tag -->
              {%- if product.compare_at_price > product.price -%}
                {%- assign savings = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                <span class="popular-product-badge-{{ section.id }}">{{ savings }}%</span>
              {%- endif -%}

              <!-- Actions on Hover -->
              <div class="popular-product-actions-{{ section.id }}">
                <button class="popular-product-icon-btn-{{ section.id }} quick-view-btn" data-product-handle="{{ product.handle }}" title="Quick View">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
                <button class="popular-product-icon-btn-{{ section.id }} wishlist-btn" data-product-id="{{ product.id }}" title="Add to Wishlist">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                </button>
              </div>

              <!-- Add to Cart overlay -->
              <div class="popular-product-quick-add-{{ section.id }}">
                {%- if product.available -%}
                  <form method="post" action="/cart/add" style="width: 100%; height: 100%;">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                    <button type="submit" class="popular-product-add-cart-btn-{{ section.id }}">ADD CART</button>
                  </form>
                {%- else -%}
                  <button class="popular-product-add-cart-btn-{{ section.id }}" disabled>SOLD OUT</button>
                {%- endif -%}
              </div>
            </div>

            <!-- Title & Pricing -->
            <a href="{{ product.url }}" class="popular-product-name-{{ section.id }}">{{ product.title }}</a>
            <div class="popular-product-price-container-{{ section.id }}">
              <span class="popular-product-price-{{ section.id }}">Rs. {{ product.price | money_without_currency }} INR</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="popular-product-compare-price-{{ section.id }}">Rs. {{ product.compare_at_price | money_without_currency }} INR</span>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback Onboarding State -->
        {%- for i in (1..4) -%}
          <div class="popular-product-card-{{ section.id }}">
            <div class="popular-product-image-container-{{ section.id }}">
              {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              <div class="popular-product-quick-add-{{ section.id }}">
                <button class="popular-product-add-cart-btn-{{ section.id }}">ADD CART</button>
              </div>
            </div>
            <a href="#" class="popular-product-name-{{ section.id }}">Sample Cosmetic Product {{ i }}</a>
            <div class="popular-product-price-container-{{ section.id }}">
              <span class="popular-product-price-{{ section.id }}">Rs. 46,000.00 INR</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Popular Products Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "POPULAR PRODUCTS OF THE WEEK"
    },
    {
      "type": "inline_html",
      "id": "title",
      "label": "Heading",
      "default": "Latest Worthwhile Collections"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "header",
      "content": "Styling Config"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Product Card Background",
      "default": "#f6f5ea"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#729855"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background Color",
      "default": "#2f3e10"
    },
    {
      "type": "color",
      "id": "btn_hover_bg_color",
      "label": "Button Hover Background Color",
      "default": "#729855"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "label": "Maximum Width",
      "default": 1280
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 84
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Popular Products Showcase"
    }
  ]
}
{% endschema %}
